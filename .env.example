# ============================================================
# CyberShield Control Center — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# Database
DATABASE_URL=postgresql+asyncpg://cybersec:password@localhost:5432/cybersec

# Security (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=your-secret-key-here-use-openssl-rand-hex-32

# App
ENVIRONMENT=development
LOG_LEVEL=INFO
FRONTEND_URL=http://localhost:3000
SYNC_INTERVAL_MINUTES=30

# Microsoft 365 / Azure AD (optional — required for live sync)
# Register an app at: https://portal.azure.com/#view/Microsoft_AAD_RegisteredApps
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=
# Redirect URI: http://localhost:8000/api/integrations/microsoft/callback

# Google Workspace (optional — required for live sync)
# Create credentials at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Redirect URI: http://localhost:8000/api/integrations/google/callback

# NextAuth.js (frontend)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-here

# Next.js public API URL
NEXT_PUBLIC_API_URL=http://localhost:8000
